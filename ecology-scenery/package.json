{
  "name": "ecology-scenery",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "title": "Ecology Simulations",
  "author": "SimLab",
  "scripts": {
    "dev": "ECOLOGY_SIM=carbon-oxygen-cycle vite",
    "dev:carbon": "ECOLOGY_SIM=carbon-oxygen-cycle vite",
    "dev:food-web": "ECOLOGY_SIM=food-web-builder vite",
    "dev:pyramid": "ECOLOGY_SIM=ecological-pyramid vite",
    "dev:predator": "ECOLOGY_SIM=predator-prey vite",
    "dev:warming": "ECOLOGY_SIM=global-warming vite",
    "build": "node ./scripts/build-all.mjs",
    "build:one": "tsc --noEmit && vite build && node ./scripts/copy-one.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "~5.7.2",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.1.0",
    "vite-raw-plugin": "^1.0.2"
  }
}
